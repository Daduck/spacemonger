{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "CMake: configure VS 2022 Win32",
			"type": "shell",
			"command": "cmake",
			"args": [
				"--preset",
				"vs2022-win32"
			],
			"group": "build",
			"problemMatcher": [],
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			}
		},
		{
			"label": "CMake: build Debug",
			"type": "shell",
			"command": "cmake",
			"args": [
				"--build",
				"--preset",
				"vs2022-win32-debug"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": "$msCompile",
			"dependsOn": "CMake: configure VS 2022 Win32",
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			}
		},
		{
			"label": "CMake: build Release",
			"type": "shell",
			"command": "cmake",
			"args": [
				"--build",
				"--preset",
				"vs2022-win32-release"
			],
			"group": "build",
			"problemMatcher": "$msCompile",
			"dependsOn": "CMake: configure VS 2022 Win32",
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			}
		},
		{
			"label": "CMake: test Debug",
			"type": "shell",
			"command": "ctest",
			"args": [
				"--preset",
				"vs2022-win32-debug"
			],
			"group": {
				"kind": "test",
				"isDefault": true
			},
			"problemMatcher": [],
			"dependsOn": "CMake: build Debug",
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			}
		}
	]
}
